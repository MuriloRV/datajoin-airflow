# Template do .env de PRODUÇÃO. Copia pra /opt/datajoin/airflow/.env na VM
# (NUNCA commitar o .env real, está no .gitignore).
#
# Vars marcadas REQUIRED não têm default — compose falha se não setar.
# Vars com default seguro podem ser omitidas.

# ─── Tag das imagens Docker ───
# NÃO setar aqui. O workflow GitHub Actions injeta IMAGE_TAG (sha-<commit-curto>)
# em cada deploy automaticamente.
# Pra rollback manual: trigger workflow_dispatch com input image_tag.

# ─── Postgres metadata (REQUIRED) ───
# Senha do role `airflow` no container `airflow-postgres` deste compose.
# Imagem oficial cria role+db `airflow` no 1o boot. Hostname interno:
# `airflow-postgres:5432`. NAO confundir com o `postgres` do datajoin-app
# (DW), que segue como host do warehouse abaixo.
AIRFLOW_DB_PASSWORD=                 # REQUIRED — gerar com `openssl rand -hex 24`

# ─── Airflow internals (REQUIRED — gerar valores fortes) ───
# Fernet — criptografa Connections (OAuth tokens etc). NUNCA trocar em prod
# sem migrar dados. Gerar com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=                  # REQUIRED
# API secret_key — assina session cookies da UI. Gerar com `openssl rand -hex 32`.
AIRFLOW_SECRET_KEY=                  # REQUIRED
# JWT compartilhado entre apiserver e scheduler (Airflow 3.x execution API).
# Tem que ser IDÊNTICO nos dois — task workers assinam token com ela.
# Gerar com `openssl rand -hex 32`.
AIRFLOW_JWT_SECRET=                  # REQUIRED

# ─── Admin bootstrap (FabAuthManager) ───
# Criado pelo airflow-init no 1o deploy via `airflow users create`. Apos
# isso, gerencia users/roles via UI (Security → List Users / List Roles).
# Re-runs do deploy sao idempotentes — se ja existir, init skipa.
AIRFLOW_ADMIN_USERNAME=admin         # opcional — default `admin`
AIRFLOW_ADMIN_PASSWORD=              # REQUIRED — senha do user admin inicial
AIRFLOW_ADMIN_EMAIL=                 # REQUIRED — email do admin (ex: ops@datajoin.cloud)

# URL pública da UI (atrás do CF tunnel). Usada pra redirects de login do FAB
# e link generation em emails. OPCIONAL — o compose.prod.yml ja tem essa URL
# como default. So setar aqui se um dia tiver staging ou outro dominio.
# AIRFLOW_BASE_URL=https://airflow.datajoin.cloud

# ─── Service-to-service (REQUIRED — bate com .env do datajoin-app) ───
SERVICE_TOKEN=                       # REQUIRED — mesmo do datajoin-app
PLATFORM_API_URL=http://api:8000     # default ok — rede dj_network

# ─── DW default (Postgres do datajoin-app) ───
# Fallback usado por DAGs sem Connection específica.
DW_DEFAULT_HOST=postgres
DW_DB_USER=dw_admin
DW_DB_PASSWORD=                      # REQUIRED — mesmo do datajoin-app
DW_DB_NAME=warehouse
