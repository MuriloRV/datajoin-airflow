# Variaveis usadas pelo deploy do Airflow no k3s da VM Hostinger.
# Self-contained: NAO le nada do .env do datajoin-app — duplique aqui o
# que for compartilhado.
#
# Local na VM: deployment/.env.prod (gitignored).
# No GitHub Actions: cada chave abaixo deve ter um repository secret de
# mesmo nome — o workflow gera o .env.prod no servidor antes do deploy.

# ─── Postgres metadata (mesmo Postgres do datajoin-app, em Docker) ───
# IP do host pra criar Endpoints do Service `dj-postgres`. Se vazio,
# setup-postgres-svc.sh descobre via kubectl get nodes.
POSTGRES_HOST_IP=
POSTGRES_PORT=5432
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=airflow

# ─── Airflow secrets ───
# Gerar com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=GERE_UMA_NOVA_KEY
# openssl rand -hex 32
AIRFLOW_SECRET_KEY=GERE_UMA_NOVA_KEY
# openssl rand -hex 32 (precisa bater entre api-server e scheduler — Airflow 3.x execution API)
AIRFLOW_JWT_SECRET=GERE_UMA_NOVA_KEY

# ─── Service-to-service com a API datajoin (datajoin-app) ───
SERVICE_TOKEN=change-me
PLATFORM_API_URL=http://localhost:8000

# ─── DW default (Postgres do Docker, mesmo host) ───
# DAGs usam quando o tenant nao tem Connection propria.
# DW_DEFAULT_HOST sai automaticamente do PG_HOST_IN_CLUSTER no script,
# nao precisa preencher aqui.
DW_DB_USER=dw_admin
DW_DB_PASSWORD=dw_admin
DW_DB_NAME=warehouse

# ─── Caminhos no host (default funciona) ───
AIRFLOW_LOGS_DIR=/var/log/datajoin-airflow
AIRFLOW_LOGS_SIZE=20Gi
