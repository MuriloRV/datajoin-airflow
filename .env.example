# в”Ђв”Ђв”Ђ Airflow в”Ђв”Ђв”Ђ
AIRFLOW_PORT=8080

# Senha do role `airflow` no Postgres dedicado deste compose (`airflow-postgres`).
# A imagem oficial provisiona role+db no 1o boot a partir desta var.
AIRFLOW_DB_PASSWORD=airflow

# Fernet key вЂ” criptografa Connections (incluindo OAuth do Conta Azul). NUNCA
# trocar em prod sem migrar dados (todas as Connections viram lixo). Gerar com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=LrngKSZWsdtlRw49EEgoxqVe9Nb-KMBjkBQJ6ivMbhQ=

# Secret key da API (assina session cookies da UI). Gerar com `openssl rand -hex 32`.
AIRFLOW_SECRET_KEY=dev-airflow-secret-change-me

# Chave JWT compartilhada entre scheduler e apiserver (execution API do 3.x).
# Tem que ser idГЄntica nos dois вЂ” task workers assinam token com ela.
AIRFLOW_JWT_SECRET=dev-airflow-jwt-shared-secret

# Credenciais do admin bootstrap (FabAuthManager). Criadas pelo airflow-init
# no 1o boot via `airflow users create`. Depois disso, gerencia via UI
# (Security в†’ List Users). Em dev, `admin/admin` basta.
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@datajoin.local

# в”Ђв”Ђв”Ђ Service-to-service в”Ђв”Ђв”Ђ
# Token usado pelo Airflow pra chamar a API datajoin (repo datajoin-app).
# Tem que bater com o SERVICE_TOKEN do .env do datajoin-app.
SERVICE_TOKEN=dev-service-token-change-me

# URL da API datajoin. Default assume rede dj_network compartilhada com o
# datajoin-app вЂ” em prod, sobrescrever pra URL pГєblica (Cloudflare Tunnel etc).
PLATFORM_API_URL=http://api:8000

# в”Ђв”Ђв”Ђ DW default (Postgres do datajoin-app) в”Ђв”Ђв”Ђ
# Usado como fallback quando o tenant nГЈo tem Airflow Connection prГіpria.
DW_DEFAULT_HOST=postgres
DW_DB_USER=dw_admin
DW_DB_PASSWORD=dw_admin
DW_DB_NAME=warehouse
